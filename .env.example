# ── Copy this file to .env and fill in your values ──────────────────────────

# A random string used to sign sessions – generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-something-random

# Your public-facing URL (no trailing slash)
BASE_URL=http://localhost:5000

# Anthropic API key for caption generation
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key for AI image generation (DALL-E 3)
# Get one at https://platform.openai.com/api-keys
# Cost: ~$0.04 per generated image
OPENAI_API_KEY=your_openai_api_key_here

# (Optional) Override where the SQLite database is stored
# DATABASE_URL=sqlite:////absolute/path/to/automation.db
